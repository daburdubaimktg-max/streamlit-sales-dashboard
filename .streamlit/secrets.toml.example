# ---------------------------------------------------------------------------
# Sales Dashboard – secrets template
#
# 1. Copy this file to ".streamlit/secrets.toml"
# 2. Fill in the values below
# 3. NEVER commit the real secrets.toml (it is git-ignored)
#
# See the README ("Live data from OneDrive/SharePoint") for how to obtain
# each value.
# ---------------------------------------------------------------------------

# --- Private access ---------------------------------------------------------
# Shared password your internal viewers type to open the dashboard.
# Leave blank if your hosting is already locked down to internal users.
APP_PASSWORD = "change-me"

# --- EASIEST live source: a public/direct-download link (NO Azure) ----------
# Paste a direct-download URL to your data file. Works with:
#   * Google Sheets published as CSV (File -> Share -> Publish to web -> CSV)
#   * A OneDrive/SharePoint "Anyone with the link" link (see README for the
#     small tweak that turns a view link into a direct-download link)
# Leave blank if you don't use this. You can also just drag-and-drop a file
# in the app's sidebar with no configuration at all.
PUBLIC_DATA_URL = ""

# --- Microsoft 365 / Graph API credentials (advanced, needs Azure setup) ----
# Created when you register an app in the Azure portal (see README).
MS_TENANT_ID = "00000000-0000-0000-0000-000000000000"
MS_CLIENT_ID = "00000000-0000-0000-0000-000000000000"
MS_CLIENT_SECRET = "your-client-secret-value"

# --- Which Excel file to read ----------------------------------------------
# EASIEST: paste the "Share" link of the Excel file from OneDrive/SharePoint.
EXCEL_SHARE_URL = "https://yourcompany-my.sharepoint.com/:x:/g/personal/..."

# ADVANCED (alternative to EXCEL_SHARE_URL): explicit Graph drive + item IDs.
# MS_DRIVE_ID = ""
# MS_ITEM_ID = ""
